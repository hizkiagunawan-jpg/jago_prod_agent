{
  "name": "8a9e347a-233e-4dd9-8b9d-004c0c51bba5",
  "displayName": "Promotion_Rewards_Collector_Page",
  "form": {
    "parameters": [ {
      "displayName": "s24_remarks_slot",
      "required": true,
      "entityType": "@sys.any",
      "fillBehavior": {
        "initialPromptFulfillment": {
          "conditionalCases": [ {
            "cases": [ {
              "condition": "$session.params.required_fields AND CONTAINS AND \"s24\"",
              "caseContent": [ {
                "message": {
                  "text": {
                    "text": [ "Please specify the promo campaign name, referral code, or Jagoan cashback reward that you have not received:" ]
                  },
                  "languageCode": "en"
                }
              }, {
                "message": {
                  "text": {
                    "text": [ "Mohon sebutkan nama program kampanye promo, kode referral, atau hadiah cashback Jagoan yang belum Anda terima:" ]
                  },
                  "languageCode": "id"
                }
              } ]
            } ]
          } ]
        }
      }
    } ]
  },
  "transitionRoutes": [ {
    "condition": "NOT ($session.params.required_fields AND CONTAINS AND \"s24\") AND $page.params.s24_remarks_slot = null",
    "triggerFulfillment": {
      "setParameterActions": [ {
        "parameter": "s24_remarks_slot",
        "value": "SKIPPED"
      } ]
    },
    "targetPage": "Promotion_Rewards_Collector_Page",
    "name": "1fe15818-cd57-4833-a68b-d6c0ecb9b7fe"
  }, {
    "condition": "$page.status = FINAL",
    "triggerFulfillment": {
      "setParameterActions": [ {
        "parameter": "s24_remarks",
        "value": "$page.params.s24_remarks_slot"
      } ]
    },
    "targetPage": "CS_Handoff_Page",
    "name": "a5467d49-e43a-4d0c-8f8d-f241727822ac"
  } ]
}
