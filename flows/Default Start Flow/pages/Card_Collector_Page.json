{
  "name": "e63c62e6-5522-4f66-ba07-61d04ae222df",
  "displayName": "Card_Collector_Page",
  "form": {
    "parameters": [ {
      "displayName": "s2_additional_info_slot",
      "required": true,
      "entityType": "@sys.any",
      "fillBehavior": {
        "initialPromptFulfillment": {
          "conditionalCases": [ {
            "cases": [ {
              "condition": "$session.params.required_fields AND CONTAINS AND \"s2\"",
              "caseContent": [ {
                "message": {
                  "text": {
                    "text": [ "Please provide additional details regarding your card delivery issue:" ]
                  },
                  "languageCode": "en"
                }
              }, {
                "message": {
                  "text": {
                    "text": [ "Mohon berikan informasi tambahan terkait laporan pengiriman kartu Anda:" ]
                  },
                  "languageCode": "id"
                }
              } ]
            } ]
          } ]
        }
      }
    }, {
      "displayName": "s5_awb_slot",
      "required": true,
      "entityType": "@sys.any",
      "fillBehavior": {
        "initialPromptFulfillment": {
          "conditionalCases": [ {
            "cases": [ {
              "condition": "$session.params.required_fields AND CONTAINS AND \"s5\"",
              "caseContent": [ {
                "message": {
                  "text": {
                    "text": [ "Please enter your card delivery tracking number (AWB):" ]
                  },
                  "languageCode": "en"
                }
              }, {
                "message": {
                  "text": {
                    "text": [ "Mohon masukkan nomor resi (AWB) pengiriman kartu Kakak:" ]
                  },
                  "languageCode": "id"
                }
              } ]
            } ]
          } ]
        }
      }
    }, {
