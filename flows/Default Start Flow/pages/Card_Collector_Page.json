              "caseContent": [ {
                "message": {
                  "text": {
                    "text": [ "Please select your delivery courier (JNT / Ninja / Sicepat):" ]
                  },
                  "languageCode": "en"
                }
              }, {
                "message": {
                  "text": {
                    "text": [ "Silakan pilih kurir pengiriman kartu Kakak (JNT / Ninja / Sicepat):" ]
                  },
                  "languageCode": "id"
                }
              } ]
            } ]
          } ]
        }
      }
    }, {
