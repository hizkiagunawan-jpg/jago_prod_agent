{
  "name": "ba1562ba-e8b4-455e-8fbc-db1452e4b90d",
  "displayName": "Fraud_Collector_Page",
  "form": {
    "parameters": [ {
      "displayName": "s24_remarks_slot",
      "required": true,
      "entityType": "@sys.any",
      "fillBehavior": {
        "initialPromptFulfillment": {
          "conditionalCases": [ {
            "cases": [ {
              "condition": "$session.params.required_fields AND CONTAINS AND \"s24\"",
              "caseContent": [ {
                "message": {
                  "text": {
                    "text": [ "SECURITY WARNING: Please explain the timeline of the suspected fraud or unauthorized access on your account:" ]
                  },
                  "languageCode": "en"
                }
              }, {
                "message": {
                  "text": {
                    "text": [ "PERINGATAN KEAMANAN: Mohon jelaskan kronologi indikasi penipuan atau akses tidak dikenal pada akun Anda:" ]
                  },
                  "languageCode": "id"
                }
              } ]
            } ]
          } ]
        }
      }
    }, {
      "displayName": "k31_result_slot",
      "required": true,
      "entityType": "@jago_entity_result_status",
      "fillBehavior": {
        "initialPromptFulfillment": {
          "conditionalCases": [ {
            "cases": [ {
              "condition": "$session.params.required_fields AND CONTAINS AND \"k31\"",
              "caseContent": [ {
                "message": {
                  "text": {
                    "text": [ "Please select the emergency action you are requesting for your current account status:" ]
                  },
                  "languageCode": "en"
                }
              }, {
                "message": {
                  "text": {
                    "text": [ "Pilih tindakan darurat yang Anda ajukan untuk status akun saat ini:" ]
                  },
                  "languageCode": "id"
                }
              } ]
            } ]
          } ]
        }
      }
    } ]
  },
  "transitionRoutes": [ {
    "condition": "NOT ($session.params.required_fields AND CONTAINS AND \"s24\") AND $page.params.s24_remarks_slot = null",
    "triggerFulfillment": {
      "setParameterActions": [ {
        "parameter": "s24_remarks_slot",
        "value": "SKIPPED"
      } ]
    },
    "targetPage": "Fraud_Collector_Page",
    "name": "57e35b9b-569d-4ee3-88fa-7e3c1acde7a8"
  }, {
    "condition": "NOT ($session.params.required_fields AND CONTAINS AND \"k31\") AND $page.params.k31_result_slot = null",
    "triggerFulfillment": {
      "setParameterActions": [ {
        "parameter": "k31_result_slot",
        "value": "SKIPPED"
      } ]
    },
    "targetPage": "Fraud_Collector_Page",
    "name": "58a0f15c-6210-471b-a4b2-97639ab331b3"
  }, {
    "condition": "$page.status = FINAL",
    "triggerFulfillment": {
      "setParameterActions": [ {
        "parameter": "s24_remarks",
        "value": "$page.params.s24_remarks_slot"
      }, {
        "parameter": "k31_result",
        "value": "$page.params.k31_result_slot"
      } ]
    },
    "targetPage": "Fraud_Handoff_Page",
    "name": "c25cb813-9c84-4879-a127-73d360f24006"
  } ]
}
